# Copy to .env: cp .env.example .env
# For production, replace all values with strong secrets (openssl rand -hex 32)
# In CI/CD, store these as GitHub Secrets and inject them as environment variables

DATABASE_URL=postgresql+asyncpg://archival:secret@db:5432/archival
API_KEY=change-me-before-deploy
POSTGRES_USER=archival
POSTGRES_PASSWORD=secret
POSTGRES_DB=archival
